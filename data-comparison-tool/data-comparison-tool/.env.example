# Server Configuration
PORT=3000
NODE_ENV=development

# Azure Storage (optional - for Azure integration)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_DEFAULT_CONTAINER=

# File Upload Settings
MAX_FILE_SIZE_MB=500
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Processing
CHUNK_SIZE=100000
MAX_WORKERS=4

# Cache TTL (seconds)
CACHE_TTL=3600

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
